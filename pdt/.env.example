DJANGO_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

POSTGRES_DB=pdt
POSTGRES_USER=pdt
POSTGRES_PASSWORD=pdt_dev_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

# Link "Pague um café" (Buy Me a Coffee, Pix, etc.)
DONATION_URL=https://www.buymeacoffee.com/seu-usuario
DONATION_LABEL=Pague um café para o criador

# Nota mínima para passar no teste de admissão (de 0 a 10)
ADMISSION_PASS_SCORE=5

# E-mail do superusuário de QA criado por `manage.py create_qa_superuser`.
# A senha é sempre gerada na hora (42 caracteres) e só aparece no stdout — não
# coloque senha aqui nem no código.
PDT_QA_SUPERUSER_EMAIL=qa@pdt.local

# Lista de servidores ICE (STUN/TURN) para a sala de voz da ajuda.
# Valor é JSON. Em produção atrás de NAT simétrico, configure um TURN
# (ex.: Coturn) e exporte algo como:
# WEBRTC_ICE_SERVERS_JSON=[{"urls":["turn:turn.example.com:3478"],"username":"u","credential":"p"}]
# WEBRTC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]}]
